@model IEnumerable<StudentApp.Models.Students>

@{
    ViewBag.Title = "Danh sách Sinh viên";
}

<div class="container" style="margin-top: 20px;">
    <h2 class="text-primary">Danh sách sinh viên</h2>

    <p>
        @Html.ActionLink("Thêm Sinh viên Mới", "Create", null, new { @class = "btn btn-primary" })
    </p>

    <table class="table table-striped table-hover table-bordered">
        <thead class="thead-dark">
            <tr>
                <th>Họ và chữ lót</th>
                <th>Tên</th>
                <th>Ngày nhập học</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.FirstName)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.LastName)
                    </td>
                    <td>
                        @item.EnrollmentDate.ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        @Html.ActionLink("Sửa", "Edit", new { id = item.StudentID }, new { @class = "btn btn-sm btn-outline-warning" }) |
                        @Html.ActionLink("Chi tiết", "Details", new { id = item.StudentID }, new { @class = "btn btn-sm btn-outline-info" }) |
                        @Html.ActionLink("Xóa", "Delete", new { id = item.StudentID }, new { @class = "btn btn-sm btn-outline-danger" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>